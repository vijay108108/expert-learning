rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      // Updates allowed on own document, but the role field cannot be changed by the user.
      // Admins may update any user's document, including role.
      allow update: if request.auth != null
        && (
          (request.auth.uid == userId
            && !('role' in request.resource.data.diff(resource.data).affectedKeys()))
          || isAdmin()
        );
    }

    match /enrollments/{enrollmentId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.canonicalCourseId is string
        && enrollmentId == request.auth.uid + "__" + request.resource.data.canonicalCourseId;
      allow update, delete: if false;
    }

    match /lms-activity/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    match /users/{userId}/notifications/{notifId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    match /qa/{courseId}/questions/{questionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Courses: public read; write restricted to admin role
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public catalog overrides/new-courses: public read; admin write
    match /catalogCourses/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Payments: authenticated users can create their own records; read own records only
    match /payments/{paymentId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // LMS modules, lessons, resources: public read; admin write
    match /modules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /lessons/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /resources/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /leads/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Phone signup claims: public read (only checks if phone is registered, not sensitive)
    // Write requires auth to prevent anonymous spam
    match /phone-signup-claims/{phone} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
