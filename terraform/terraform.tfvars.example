subnet_name                 = "genznext-subnet"
subnet_address_prefixes     = ["10.0.1.0/24"]
network_security_group_name = "genznext-nsg"

admin_username         = "azureuser"
admin_ssh_public_key   = "ssh-rsa REPLACE_WITH_PUBLIC_KEY_ONLY"
