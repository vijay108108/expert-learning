application_port       = 3000
vm_size                = "Standard_D2s_v3"

common_tags = {
  application = "expert-learning"
  environment = "shared"
  managed-by  = "terraform"
}

vms = {
  dev = {
    vm_name           = "dev-vm"
    nic_name          = "dev-nic"
